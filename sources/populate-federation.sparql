# java -jar ../tools/sparql-anything.jar -q populate-federation.sparql \
#   -v location=sozialplattform/raw/sozialplattform.json \
#   -v source=sp \
#   -f TTL > federation.ttl

PREFIX xyz: <http://sparql.xyz/facade-x/data/>
PREFIX fx:  <http://sparql.xyz/facade-x/ns/>
PREFIX : <https://civic-data.de/pipeline#>

CONSTRUCT {
    ?sourceIri a :Source ;
        :location    ?_location ;
        :format      "json" ;
        :hasField    ?topFieldIri .

    ?topFieldIri a :SourceField ;
        :fieldPath   ?topFieldName ;
        :fieldKind   ?topFieldKind ;
        :hasSubField ?subFieldIri .

    ?subFieldIri a :SourceField ;
        :fieldPath ?subFieldName .
} WHERE {
    SERVICE <x-sparql-anything:> {
        fx:properties fx:location ?_location ;
            fx:json.include-null-values true .
        ?root ?listIdx ?entry .
        ?entry ?topField ?topValue .
        FILTER(STRSTARTS(STR(?topField), STR(xyz:)))
        OPTIONAL {
            ?topValue ?subField ?subValue .
            FILTER(STRSTARTS(STR(?subField), STR(xyz:)))
            BIND("object" AS ?topFieldKind)
        }
    }
    BIND("https://civic-data.de/pipeline#" AS ?ns)
    BIND(IRI(CONCAT(?ns, ?_source))                         AS ?sourceIri)
    BIND(REPLACE(STR(?topField), "^.*/", "")                AS ?topFieldName)
    BIND(IRI(CONCAT(?ns, ?_source, "-", ?topFieldName))     AS ?topFieldIri)
    BIND(REPLACE(STR(?subField), "^.*/", "")                AS ?subFieldName)
    BIND(IRI(CONCAT(?ns, ?_source, "-", ?subFieldName))     AS ?subFieldIri)
}
