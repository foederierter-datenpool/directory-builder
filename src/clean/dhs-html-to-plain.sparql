# Reshape SPARQL-Anything's facade-x HTML lifting into flat dhs:Entry records.
# %5Bentry%5D= is URL-encoded "[entry]=", the entry ID key in DHS detail links.

PREFIX rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xhtml: <http://www.w3.org/1999/xhtml#>
PREFIX html:  <https://html.spec.whatwg.org/#>
PREFIX dhs:   <https://civic-data.de/dhs#>

CONSTRUCT {
    ?iri a dhs:Entry ;
        dhs:name       ?name ;
        dhs:detailLink ?detailHref ;
        ?predicate     ?value .
} WHERE {
    ?entry a xhtml:li .

    ?entry (rdf:_1|rdf:_2|rdf:_3|rdf:_4|rdf:_5)+ ?titleA .
    ?titleA a xhtml:a ;
            xhtml:href ?detailHref ;
            html:innerText ?name .
    FILTER(CONTAINS(STR(?detailHref), "%5Bentry%5D="))

    ?entry (rdf:_1|rdf:_2|rdf:_3|rdf:_4|rdf:_5)+ ?leafSpan .
    ?leafSpan a xhtml:span ;
              xhtml:class ?className ;
              html:innerText ?value .
    BIND(IRI(CONCAT(STR(dhs:), ?className)) AS ?predicate)

    BIND(IRI(CONCAT(STR(dhs:), "entry-",
        STRBEFORE(STRAFTER(STR(?detailHref), "%5Bentry%5D="), "&"))) AS ?iri)
}
